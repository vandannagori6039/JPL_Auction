<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JPL Auction - Live Display</title>
    <link rel="stylesheet" href="/css/display.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="display-container">
        
        <!-- Header -->
        <header class="display-header">
            <div class="header-content">
                <h1 class="tournament-title">🏏 JAIN PREMIER LEAGUE</h1>
                <div class="header-stats">
                    <span class="header-stat">
                        Round: <strong id="displayRound"><%= auctionState.roundNumber || 0 %></strong>
                    </span>
                    <span class="header-stat">
                        Sold: <strong id="displaySold"><%= soldCount %></strong>/<%= totalPlayers %>
                    </span>
                    <span class="header-stat connection-status" id="connectionStatus">
                        🟢 Live
                    </span>
                </div>
            </div>
        </header>

        <!-- Main Display Area -->
        <main class="display-main">
            
            <!-- Current Player Section -->
            <section class="current-player-section" id="currentPlayerSection">
                <% if (currentPlayer) { %>
                    <div class="player-display">
                        <div class="player-display-left">
                            <div class="player-display-number">#<%= currentPlayer.playerNumber %></div>
                            <h2 class="player-display-name"><%= currentPlayer.name %></h2>
                            <div class="player-display-category">
                                <span class="category-badge cat-<%= currentPlayer.category %>">
                                    CATEGORY <%= currentPlayer.category %>
                                </span>
                            </div>
                            <div class="player-display-base">
                                Base Price: ₹<%= currentPlayer.basePrice.toLocaleString('en-IN') %>
                            </div>
                        </div>
                        
                        <div class="player-display-right">
                            <div class="current-bid-section">
                                <div class="bid-header">CURRENT BID</div>
                                <div class="bid-display-amount" id="displayBidAmount">
                                    ₹<%= (auctionState.currentBid || currentPlayer.basePrice).toLocaleString('en-IN') %>
                                </div>
                                <div class="bid-display-team" id="displayBiddingTeam" <% if (currentBidder) { %>style="color: <%= currentBidder.color %>"<% } %>>
                                    <% if (currentBidder) { %>
                                        <%= currentBidder.teamName %>
                                    <% } else { %>
                                        Waiting for bids...
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="no-auction">
                        <div class="no-auction-content">
                            <h2>AUCTION STARTING SOON</h2>
                            <p>Please wait for the auction to begin</p>
                        </div>
                    </div>
                <% } %>
            </section>

            <!-- Teams Grid Section -->
            <section class="teams-display-section">
                <div class="teams-display-grid" id="teamsDisplayGrid">
                    <% teams.forEach(team => { %>
                        <div class="team-display-card" data-team-id="<%= team._id %>" style="border-top: 5px solid <%= team.color %>">
                            <div class="team-display-header" style="background: <%= team.color %>">
                                <h3><%= team.teamName %></h3>
                            </div>
                            <div class="team-display-body">
                                <div class="team-display-row">
                                    <span class="label">Players</span>
                                    <span class="value players-count">
                                        <%= team.playersCount %>/11
                                    </span>
                                </div>
                                <div class="team-display-progress">
                                    <div class="progress-bar-display">
                                        <div class="progress-fill-display" style="width: <%= (team.playersCount / 11) * 100 %>%; background: <%= team.color %>"></div>
                                    </div>
                                </div>
                                <div class="team-display-row">
                                    <span class="label">Purse</span>
                                    <span class="value purse-value">
                                        ₹<%= team.remainingPurse.toLocaleString('en-IN') %>
                                    </span>
                                </div>
                                <div class="team-display-row">
                                    <span class="label">Spent</span>
                                    <span class="value spent-value">
                                        ₹<%= ((team.initialPurse || 100000) - team.remainingPurse).toLocaleString('en-IN') %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </section>
        </main>
    </div>

    <!-- Sold Overlay -->
    <div id="soldOverlay" class="sold-overlay-display" style="display: none;">
        <div class="sold-content-display">
            <h1 class="sold-text">SOLD!</h1>
            <div class="sold-details-display">
                <p class="sold-player-name" id="soldPlayerName"></p>
                <p class="sold-team-name" id="soldTeamName"></p>
                <p class="sold-price-display" id="soldPrice"></p>
            </div>
        </div>
    </div>

    <!-- Unsold Overlay -->
    <div id="unsoldOverlay" class="unsold-overlay-display" style="display: none;">
        <div class="unsold-content-display">
            <h1 class="unsold-text">UNSOLD</h1>
            <p class="unsold-player-name" id="unsoldPlayerName"></p>
        </div>
    </div>

    <script src="/js/display.js"></script>
</body>
</html>
