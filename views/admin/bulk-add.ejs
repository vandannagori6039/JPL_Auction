<%- include('../partials/header', {title: 'Bulk Add Players', showNav: true}) %>

<div class="bulk-add-container">
    <div class="page-header">
        <h1>Bulk Add Players</h1>
        <p>Add multiple players at once</p>
    </div>

    <div class="bulk-info">
        <p>Enter player details in the table below. You can add up to 50 players at once.</p>
        <p><strong>Tip:</strong> Empty rows will be ignored automatically.</p>
    </div>

    <div id="result-message"></div>

    <form id="bulkAddForm">
        <div class="table-controls">
            <button type="button" class="btn btn-secondary" onclick="addMoreRows(10)">
                Add 10 More Rows
            </button>
            <button type="button" class="btn btn-secondary" onclick="clearAllRows()">
                Clear All
            </button>
        </div>

        <div class="table-responsive">
            <table class="bulk-table" id="bulkTable">
                <thead>
                    <tr>
                        <th style="width: 50px;">S.No.</th>
                        <th style="width: 200px;">Player Name *</th>
                        <th style="width: 150px;">WhatsApp Name</th>
                        <th style="width: 150px;">Phone Number *</th>
                        <th style="width: 150px;">Category *</th>
                        <th style="width: 80px;">Action</th>
                    </tr>
                </thead>
                <tbody id="bulkTableBody">
                    <!-- Initial 20 rows will be generated by JavaScript -->
                </tbody>
            </table>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                Submit All Players
            </button>
            <a href="/admin/players" class="btn btn-outline">Cancel</a>
        </div>
    </form>

    <div class="bulk-tips">
        <h3>Instructions:</h3>
        <ul>
            <li>Fields marked with * are mandatory</li>
            <li>Phone numbers must be exactly 10 digits</li>
            <li>Phone numbers must be unique</li>
            <li>Empty rows will be automatically skipped</li>
            <li>You'll see a summary after submission</li>
        </ul>
    </div>
</div>

<script>
let rowCount = 0;

// Generate initial rows on page load
document.addEventListener('DOMContentLoaded', () => {
    addMoreRows(20);
});

function addMoreRows(count) {
    const tbody = document.getElementById('bulkTableBody');
    for (let i = 0; i < count; i++) {
        rowCount++;
        const row = createRow(rowCount);
        tbody.appendChild(row);
    }
}

function createRow(num) {
    const tr = document.createElement('tr');
    tr.innerHTML = `
        <td class="row-number">${num}</td>
        <td>
            <input 
                type="text" 
                name="players[${num-1}][name]" 
                class="form-control form-control-sm"
                placeholder="Player name"
            >
        </td>
        <td>
            <input 
                type="text" 
                name="players[${num-1}][whatsappName]" 
                class="form-control form-control-sm"
                placeholder="WhatsApp name"
            >
        </td>
        <td>
            <input 
                type="tel" 
                name="players[${num-1}][phoneNumber]" 
                class="form-control form-control-sm phone-input"
                placeholder="10 digits"
                maxlength="10"
                pattern="[0-9]{10}"
            >
        </td>
        <td>
            <select name="players[${num-1}][category]" class="form-control form-control-sm">
                <option value="">Select</option>
                <option value="A">A</option>
                <option value="B">B</option>
                <option value="C">C</option>
                <option value="D">D</option>
            </select>
        </td>
        <td>
            <button type="button" class="btn btn-sm btn-danger" onclick="deleteRow(this)">
                ✕
            </button>
        </td>
    `;
    return tr;
}

function deleteRow(btn) {
    btn.closest('tr').remove();
}

function clearAllRows() {
    if (confirm('Are you sure you want to clear all rows?')) {
        document.getElementById('bulkTableBody').innerHTML = '';
        rowCount = 0;
        addMoreRows(20);
    }
}

// Phone number validation
document.addEventListener('input', (e) => {
    if (e.target.classList.contains('phone-input')) {
        e.target.value = e.target.value.replace(/[^0-9]/g, '');
    }
});

// Form submission
document.getElementById('bulkAddForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const players = [];
    
    // Collect all non-empty rows
    const rows = document.querySelectorAll('#bulkTableBody tr');
    rows.forEach((row, index) => {
        const name = formData.get(`players[${index}][name]`);
        const phone = formData.get(`players[${index}][phoneNumber]`);
        const category = formData.get(`players[${index}][category]`);
        
        // Only add if name, phone, and category are provided
        if (name && phone && category) {
            players.push({
                name: name.trim(),
                whatsappName: formData.get(`players[${index}][whatsappName]`)?.trim() || '',
                phoneNumber: phone.trim(),
                category: category
            });
        }
    });
    
    if (players.length === 0) {
        showMessage('Please fill at least one complete row', 'error');
        return;
    }
    
    // Show loading
    showMessage('Adding players... Please wait', 'info');
    
    try {
        const response = await fetch('/admin/players/bulk', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ players })
        });
        
        const result = await response.json();
        
        if (result.success) {
            showMessage(`Successfully added ${result.added} players!`, 'success');
            
            // Show failed entries if any
            if (result.failed && result.failed.length > 0) {
                let failedMsg = `<br><strong>Failed entries:</strong><br>`;
                result.failed.forEach(f => {
                    failedMsg += `Row ${f.row}: ${f.reason}<br>`;
                });
                showMessage(result.message + failedMsg, 'warning');
            }
            
            // Clear form after success
            setTimeout(() => {
                document.getElementById('bulkTableBody').innerHTML = '';
                rowCount = 0;
                addMoreRows(20);
            }, 3000);
        } else {
            showMessage(result.message || 'Failed to add players', 'error');
        }
    } catch (error) {
        showMessage('Error: ' + error.message, 'error');
    }
});

function showMessage(message, type) {
    const messageDiv = document.getElementById('result-message');
    messageDiv.className = `alert alert-${type}`;
    messageDiv.innerHTML = message;
    messageDiv.style.display = 'block';
    
    if (type === 'success') {
        setTimeout(() => {
            messageDiv.style.display = 'none';
        }, 5000);
    }
}
</script>

<%- include('../partials/footer') %>
