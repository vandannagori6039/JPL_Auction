<%- include('../partials/header', {title: team.teamName + ' Details', showNav: true}) %>

<div class="team-details-container">
    <!-- Team Header -->
    <div class="team-details-header" style="border-left: 5px solid <%= team.color %>">
        <div class="header-content">
            <h1 style="color: <%= team.color %>"><%= team.teamName %></h1>
            <span class="team-badge" style="background: <%= team.color %>">
                Team #<%= team.teamNumber %>
            </span>
        </div>
        <a href="/admin/teams" class="btn btn-secondary">Back to Teams</a>
    </div>

    <!-- Team Statistics -->
    <div class="stats-grid">
        <div class="stat-box">
            <h3><%= team.playersCount %>/11</h3>
            <p>Squad Strength</p>
            <small><%= 11 - team.playersCount %> slots remaining</small>
        </div>
        <div class="stat-box">
            <h3>₹<%= team.remainingPurse.toLocaleString('en-IN') %></h3>
            <p>Remaining Purse</p>
            <small><%= ((team.remainingPurse / 100000) * 100).toFixed(1) %>% left</small>
        </div>
        <div class="stat-box">
            <h3>₹<%= totalSpent.toLocaleString('en-IN') %></h3>
            <p>Total Spent</p>
            <small><%= ((totalSpent / 100000) * 100).toFixed(1) %>% used</small>
        </div>
        <div class="stat-box">
            <h3>₹<%= maxBidAllowed.toLocaleString('en-IN') %></h3>
            <p>Max Bid Allowed</p>
            <small>For next player</small>
        </div>
    </div>

    <!-- Squad Composition -->
    <div class="squad-section">
        <h2>Squad Composition by Category</h2>
        <div class="composition-grid">
            <div class="comp-card comp-A">
                <h3>Category A</h3>
                <p class="comp-count"><%= categoryBreakdown.A || 0 %> players</p>
                <p class="comp-value">₹<%= categorySpending.A.toLocaleString('en-IN') %></p>
            </div>
            <div class="comp-card comp-B">
                <h3>Category B</h3>
                <p class="comp-count"><%= categoryBreakdown.B || 0 %> players</p>
                <p class="comp-value">₹<%= categorySpending.B.toLocaleString('en-IN') %></p>
            </div>
            <div class="comp-card comp-C">
                <h3>Category C</h3>
                <p class="comp-count"><%= categoryBreakdown.C || 0 %> players</p>
                <p class="comp-value">₹<%= categorySpending.C.toLocaleString('en-IN') %></p>
            </div>
            <div class="comp-card comp-D">
                <h3>Category D</h3>
                <p class="comp-count"><%= categoryBreakdown.D || 0 %> players</p>
                <p class="comp-value">₹<%= categorySpending.D.toLocaleString('en-IN') %></p>
            </div>
        </div>
    </div>

    <!-- Players List -->
    <div class="players-section">
        <h2>Squad Players (<%= team.playersCount %>)</h2>
        
        <% if (team.players && team.players.length > 0) { %>
            <table class="squad-table">
                <thead>
                    <tr>
                        <th>S.No.</th>
                        <th>Player Name</th>
                        <th>Category</th>
                        <th>Base Price</th>
                        <th>Price Paid</th>
                        <th>Value</th>
                        <th>Bought At</th>
                    </tr>
                </thead>
                <tbody>
                    <% team.players.forEach((p, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><strong><%= p.playerName %></strong></td>
                            <td>
                                <span class="badge badge-<%= p.category %>">
                                    <%= p.category %>
                                </span>
                            </td>
                            <td>₹<%= p.playerId.basePrice.toLocaleString('en-IN') %></td>
                            <td class="price-paid">₹<%= p.pricePaid.toLocaleString('en-IN') %></td>
                            <td>
                                <% const value = ((p.pricePaid / p.playerId.basePrice) * 100).toFixed(0); %>
                                <span class="value-indicator value-<%= value > 150 ? 'high' : value < 100 ? 'low' : 'fair' %>">
                                    <%= value %>%
                                </span>
                            </td>
                            <td><%= new Date(p.boughtAt).toLocaleString() %></td>
                        </tr>
                    <% }) %>
                </tbody>
                <tfoot>
                    <tr class="total-row">
                        <td colspan="4"><strong>TOTAL</strong></td>
                        <td colspan="3"><strong>₹<%= totalSpent.toLocaleString('en-IN') %></strong></td>
                    </tr>
                </tfoot>
            </table>
        <% } else { %>
            <div class="no-players">
                <p>No players bought yet</p>
            </div>
        <% } %>
    </div>

    <!-- Insights -->
    <div class="insights-section">
        <h2>Team Insights</h2>
        <div class="insights-grid">
            <div class="insight-card">
                <h4>Most Expensive Player</h4>
                <% if (mostExpensivePlayer) { %>
                    <p><%= mostExpensivePlayer.name %></p>
                    <p class="insight-value">₹<%= mostExpensivePlayer.price.toLocaleString('en-IN') %></p>
                <% } else { %>
                    <p>-</p>
                <% } %>
            </div>
            <div class="insight-card">
                <h4>Best Value Buy</h4>
                <% if (bestValuePlayer) { %>
                    <p><%= bestValuePlayer.name %></p>
                    <p class="insight-value"><%= bestValuePlayer.valuePercent %>% of base</p>
                <% } else { %>
                    <p>-</p>
                <% } %>
            </div>
            <div class="insight-card">
                <h4>Recommended Budget</h4>
                <p>Per Remaining Player</p>
                <p class="insight-value">₹<%= recommendedBudget.toLocaleString('en-IN') %></p>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
