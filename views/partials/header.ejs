<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'JPL Auction' %></title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Styles -->
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/admin-animations.css">

    <!-- Socket.IO + Confetti -->
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <% if (typeof showNav !== 'undefined' && showNav) { %>
    <nav class="admin-nav">
        <div class="nav-container">
            <div class="nav-brand">
                <img src="/images/JPL_Logo.png" alt="JPL Logo" class="nav-logo">
                <h2>Jain Premier League</h2>
            </div>

            <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                <i class="fa-solid fa-bars"></i>
            </button>

            <ul class="nav-menu" id="navMenu">
                <li><a href="/admin/dashboard" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>"><i class="fa-solid fa-gauge-high"></i> Dashboard</a></li>
                <li><a href="/admin/players" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'players' ? 'active' : '' %>"><i class="fa-solid fa-users"></i> Players</a></li>
                <li><a href="/admin/teams" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'teams' ? 'active' : '' %>"><i class="fa-solid fa-shield-halved"></i> Teams</a></li>
                <li><a href="/admin/auction" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'auction' ? 'active' : '' %>"><i class="fa-solid fa-gavel"></i> Auction</a></li>
                <li><a href="/admin/reports" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'reports' ? 'active' : '' %>"><i class="fa-solid fa-chart-column"></i> Reports</a></li>
                <li><a href="/admin/settings" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>"><i class="fa-solid fa-gear"></i> Settings</a></li>
                <li>
                    <form action="/admin/logout" method="POST" style="display: inline;">
                        <button type="submit" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Logout</button>
                    </form>
                </li>
            </ul>
        </div>
    </nav>
    <% } %>
    <main class="main-content" id="main-content">
